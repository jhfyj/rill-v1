# ─── Admin Auth ──────────────────────────────────────────────────────────────
# The password the client uses to log in to /admin
ADMIN_PASSWORD=your-secure-password-here

# A long random secret used to sign the session cookie.
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_SESSION_SECRET=your-random-secret-here

# ─── Upstash Redis (database) ────────────────────────────────────────────────
# Get these from https://console.upstash.com after creating a Redis database.
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token-here
